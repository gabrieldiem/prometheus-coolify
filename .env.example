PROM_USER=REPLACE_WITH_ACTUAL_VALUE
PROM_PASS=REPLACE_WITH_ACTUAL_VALUE
PROM_PASS_HASH=REPLACE_WITH_ACTUAL_VALUE

PUSHGW_USER=REPLACE_WITH_ACTUAL_VALUE
PUSHGW_PASS=REPLACE_WITH_ACTUAL_VALUE
PUSHGW_PASS_HASH=REPLACE_WITH_ACTUAL_VALUE

# Optional: JSON array of extra Grafana dashboards to download at startup.
# Added on top of the base dashboards in dashboards.conf. Keep on a single line.
# Grafana.com entry:  {"type":"grafana","id":"1860","file":"node-exporter.json","title":"Node Exporter"}
# Raw URL entry:      {"type":"url","url":"https://example.com/dash.json","file":"dash.json","title":"My Dashboard"}
#DASHBOARDS=[{"type":"grafana","id":"1860","file":"node-exporter-linux-info.json","title":"Node-exporter: Linux Info (1860)"},{"type":"grafana","id":"19908","file":"cadvisor-general-cpu-absolute.json","title":"CAdvisor: General [CPU absolute] (19908)"}]
